# 环境变量（绝对不能提交）
.env
.env.local
.env.*.local

# Python 缓存
__pycache__/
*.py[cod]
*.pyo

# 虚拟环境
venv/
.venv/
env/

# 用户上传和生成的图片（运行时产生，无需提交）
static/uploads/*
static/results/*
static/hair_extracted/*

# 保留目录结构（空目录占位）
!static/uploads/.gitkeep
!static/results/.gitkeep
!static/hair_extracted/.gitkeep

# macOS 系统文件
.DS_Store

# IDE 配置
.vscode/
.idea/

# 日志
*.log
